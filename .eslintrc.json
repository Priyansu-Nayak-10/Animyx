{
  "env": {
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "overrides": [
    {
      "files": ["apps/api/**/*.js"],
      "env": {
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "commonjs"
      },
      "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-undef": "error",
        "no-console": "off",
        "eqeqeq": ["error", "always"],
        "no-var": "error",
        "prefer-const": "warn",
        "no-duplicate-imports": "error",
        "no-unreachable": "error",
        "no-constant-condition": "warn"
      }
    },
    {
      "files": ["apps/web/src/**/*.js"],
      "env": {
        "browser": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-undef": "error",
        "eqeqeq": ["error", "always"],
        "no-var": "error",
        "prefer-const": "warn",
        "no-duplicate-imports": "error",
        "no-unreachable": "error",
        "no-constant-condition": "warn"
      }
    }
  ]
}
